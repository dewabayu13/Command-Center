# .env.example
# Database type toggle ('local' or 'firebase')
VITE_DB_TYPE=local

# API Base URL for backend integrations
VITE_API_URL=http://localhost:3000/api

# Enable developer-oriented logger ('true' or 'false')
VITE_ENABLE_LOGGER=true

# Firebase config (for Phase 3)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# Gemini API Key for server-side AI Assistant (automatically set by the platform)
GEMINI_API_KEY=

